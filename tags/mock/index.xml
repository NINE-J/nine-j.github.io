&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="w"> &lt;/span>&lt;span class="n">sus&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="na">signUp&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="k">new&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="n">User&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="s">&amp;#34;test@test.com&amp;#34;&lt;/span>&lt;span class="p">));&lt;/span>&lt;span class="w">
